# Google OAuth configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id,your-android-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=8000
NODE_ENV=production

# CORS - Allowed Origins (comma-separated)
# Example: https://yourfrontend.com,https://www.yourfrontend.com
ALLOWED_ORIGINS=https://yourfrontend.com

# R2 object storage configuration
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=your-r2-bucket
R2_PUBLIC_URL=https://your-public-r2-domain

DOCUMENT_PREVIEW_SECRET=your-document-preview-secret
DOCUMENT_PREVIEW_TOKEN_TTL=2m
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760

# API base URL for absolute preview URLs (optional)
API_BASE_URL=https://api.yoursite.com

# Optional URL to redirect after successful Drive connection
FRONTEND_DRIVE_CONNECTED_REDIRECT=https://coach.subhrajyotisahoo.cloud/drive-connected

# RevenueCat configuration
REVENUECAT_API_KEY=goog_your_revenuecat_public_sdk_key
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Firebase Cloud Messaging (push notifications)
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep literal \n separators when using a single-line private key value
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY_CONTENT\\n-----END PRIVATE KEY-----\\n"

# Gemini AI configuration
GEMINI_API_KEY=your-gemini-api-key
# Optional: comma-separated model preference order
# Example: GEMINI_MODEL=gemini-2.0-flash,gemini-1.5-flash-latest
GEMINI_MODEL=gemini-2.0-flash
