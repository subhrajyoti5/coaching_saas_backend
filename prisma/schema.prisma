generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CoachingCenter {
  id               Int                    @id @default(autoincrement())
  name             String
  phone            String?
  address          String?
  description      String?
  owner_user_id    Int?
  name_updated_at  DateTime?              @db.Timestamp(6)
  created_at       DateTime?              @default(now()) @db.Timestamp(6)

  users               User[]
  subscriptions       CoachingSubscription[]
  subscription_events SubscriptionEvent[]
  batches             Batch[]
  subjects            Subject[]
  tests               Test[]
  notices             Notice[]
  access_codes        AccessCode[]
  join_requests       JoinRequest[]
  syllabuses          Syllabus[]
  ai_generations      AiGeneration[]
  questions           Question[]
  topics              Topic[]
  content_sources     ContentSource[]
  test_attempts       TestAttempt[]

  @@map("coaching_centers")
}

model Plan {
  id           Int    @id @default(autoincrement())
  name         String
  price        Int
  max_students Int?
  max_batches  Int?
  max_teachers Int?

  subscriptions CoachingSubscription[]

  @@map("plans")
}

model CoachingSubscription {
  id                       Int       @id @default(autoincrement())
  coaching_center_id       Int?
  plan_id                  Int?
  start_date               DateTime? @db.Date
  end_date                 DateTime? @db.Date
  status                   String?
  razorpay_subscription_id String?   @unique
  razorpay_plan_id         String?
  razorpay_customer_id     String?
  current_start            DateTime? @db.Timestamp(6)
  current_end              DateTime? @db.Timestamp(6)
  grace_end                DateTime? @db.Timestamp(6)
  cancel_at                DateTime? @db.Timestamp(6)
  cancelled_at             DateTime? @db.Timestamp(6)
  payment_fail_count       Int?      @default(0)
  provider                 String?   @default("revenuecat")
  revenuecat_app_user_id   String?
  entitlement_id           String?
  product_id               String?
  original_transaction_id  String?
  expires_at               DateTime? @db.Timestamp(6)
  last_event_type          String?
  last_event_at            DateTime? @db.Timestamp(6)
  metadata                 Json?

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  plan            Plan?           @relation(fields: [plan_id], references: [id])

  @@map("coaching_subscriptions")
}

model SubscriptionEvent {
  id                 Int      @id @default(autoincrement())
  coaching_center_id Int
  provider           String
  provider_event_id  String   @unique
  event_type         String
  payload            Json?
  processed_at       DateTime @default(now()) @db.Timestamp(6)

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)

  @@index([coaching_center_id, processed_at], map: "idx_subscription_events_center_processed")
  @@map("subscription_events")
}

model User {
  id                  Int       @id @default(autoincrement())
  name                String
  email               String
  phone               String?
  role                String
  coaching_center_id  Int?
  is_active           Boolean?  @default(true)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  last_login          DateTime? @db.Timestamp(6)
  trial_active        Boolean?  @default(false)
  trial_end           DateTime? @db.Timestamp(6)
  subscription_status String?   @default("inactive")
  subscription_id     String?
  current_period_end  DateTime? @db.Timestamp(6)
  grace_period_end    DateTime? @db.Timestamp(6)
  plan_type           String?   @default("basic")

  coaching_center   CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  created_batches   Batch[]         @relation("BatchCreatedBy")
  batch_subjects    BatchSubject[]  @relation("BatchSubjectTeacher")
  batch_students    BatchStudent[]  @relation("BatchStudentUser")
  schedules         BatchSchedule[] @relation("BatchScheduleTeacher")
  lectures          Lecture[]       @relation("LectureTeacher")
  attendance        Attendance[]    @relation("AttendanceStudent")
  created_tests     Test[]          @relation("TestCreatedBy")
  attempts          TestAttempt[]   @relation("TestAttemptStudent")
  fees              Fee[]           @relation("FeeStudent")
  payments_recorded Payment[]       @relation("PaymentRecordedBy")
  created_claims    PaymentClaim[]  @relation("ClaimCreatedBy")
  verified_claims   PaymentClaim[]  @relation("ClaimVerifiedBy")
  approved_claims   PaymentClaim[]  @relation("ClaimApprovedBy")
  created_notices   Notice[]        @relation("NoticeCreatedBy")
  documents         Document[]      @relation("DocumentUploadedBy")
  device_tokens     DeviceToken[]
  uploaded_syllabuses Syllabus[]    @relation("SyllabusUploadedBy")
  content_sources   ContentSource[]
  created_questions Question[]      @relation("QuestionCreatedBy")
  ai_generations    AiGeneration[]  @relation("AiGenerationTeacher")

  @@unique([email, coaching_center_id], map: "uniq_users_email_center")
  @@index([coaching_center_id], map: "idx_users_center")
  @@map("users")
}

model DeviceToken {
  id           Int       @id @default(autoincrement())
  user_id      Int
  token        String    @unique
  platform     String
  is_active    Boolean   @default(true)
  app_version  String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  last_seen_at DateTime? @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_active], map: "idx_device_tokens_user_active")
  @@map("device_tokens")
}

model AccessCode {
  id                 Int      @id @default(autoincrement())
  code               String   @unique
  role               String
  coaching_center_id Int
  expires_at         DateTime
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([coaching_center_id, role, is_active, expires_at], map: "idx_access_codes_center_role_active")
  @@map("access_codes")
}

model JoinRequest {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String
  role               String
  coaching_center_id Int
  status             String   @default("PENDING")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  expires_at         DateTime

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)

  @@unique([email, coaching_center_id, role])
  @@index([status])
  @@index([expires_at])
  @@index([coaching_center_id, role, status, created_at], map: "idx_join_requests_owner_queue")
  @@map("join_requests")
}

model Batch {
  id                 Int       @id @default(autoincrement())
  name               String
  coaching_center_id Int?
  price              Int       @default(0)
  created_by         Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  creator         User?           @relation("BatchCreatedBy", fields: [created_by], references: [id])
  batch_subjects  BatchSubject[]
  batch_students  BatchStudent[]
  schedules       BatchSchedule[]
  lectures        Lecture[]
  test_batches    TestBatch[]
  tests           Test[]
  attempts        TestAttempt[]
  fees            Fee[]
  payment_claims  PaymentClaim[]
  notice_targets  NoticeTarget[]
  documents       Document[]
  syllabuses      Syllabus[] @relation("SyllabusBatch")

  @@index([coaching_center_id], map: "idx_batches_center")
  @@map("batches")
}

model Subject {
  id                 Int    @id @default(autoincrement())
  name               String
  coaching_center_id Int?

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  batch_subjects  BatchSubject[]
  schedules       BatchSchedule[]
  lectures        Lecture[]
  tests           Test[] @relation("TestSubject")
  documents       Document[]
  syllabuses      Syllabus[] @relation("SyllabusSubject")
  questions       Question[] @relation("QuestionSubject")

  @@index([coaching_center_id], map: "idx_subjects_center")
  @@map("subjects")
}

model BatchSubject {
  id         Int  @id @default(autoincrement())
  batch_id   Int?
  subject_id Int?
  teacher_id Int?

  batch   Batch?   @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  teacher User?    @relation("BatchSubjectTeacher", fields: [teacher_id], references: [id])

  @@map("batch_subjects")
}

model BatchStudent {
  id         Int       @id @default(autoincrement())
  batch_id   Int?
  student_id Int?
  joined_at  DateTime? @default(now()) @db.Timestamp(6)

  batch   Batch? @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  student User?  @relation("BatchStudentUser", fields: [student_id], references: [id])

  @@index([batch_id], map: "idx_batch_students_batch")
  @@map("batch_students")
}

model BatchSchedule {
  id          Int       @id @default(autoincrement())
  batch_id    Int?
  subject_id  Int?
  teacher_id  Int?
  day_of_week Int?
  start_time  DateTime? @db.Time(6)
  end_time    DateTime? @db.Time(6)

  batch   Batch?   @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subject_id], references: [id])
  teacher User?    @relation("BatchScheduleTeacher", fields: [teacher_id], references: [id])

  @@map("batch_schedule")
}

model Lecture {
  id           Int       @id @default(autoincrement())
  batch_id     Int?
  subject_id   Int?
  teacher_id   Int?
  lecture_date DateTime? @db.Date
  start_time   DateTime? @db.Time(6)
  end_time     DateTime? @db.Time(6)
  topic        String?

  batch      Batch?       @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  subject    Subject?     @relation(fields: [subject_id], references: [id])
  teacher    User?        @relation("LectureTeacher", fields: [teacher_id], references: [id])
  attendance Attendance[]
  documents  Document[]

  @@map("lectures")
}

model Attendance {
  id         Int       @id @default(autoincrement())
  lecture_id Int?
  student_id Int?
  status     String?
  marked_at  DateTime? @default(now()) @db.Timestamp(6)

  lecture Lecture? @relation(fields: [lecture_id], references: [id], onDelete: Cascade)
  student User?    @relation("AttendanceStudent", fields: [student_id], references: [id])

  @@index([lecture_id], map: "idx_attendance_lecture")
  @@map("attendance")
}

// ============ SYLLABUS & AI GENERATION ============
model Syllabus {
  id                 Int       @id @default(autoincrement())
  coaching_center_id Int
  batch_id           Int?
  subject_id         Int?
  uploaded_by        Int
  name               String?
  version            Int       @default(1)
  storage_urls       Json      @db.Json
  extracted_text     String?   @db.Text
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  uploader        User           @relation("SyllabusUploadedBy", fields: [uploaded_by], references: [id])
  batch           Batch?         @relation("SyllabusBatch", fields: [batch_id], references: [id])
  subject         Subject?       @relation("SyllabusSubject", fields: [subject_id], references: [id])
  questions       Question[]     @relation("QuestionsFromSyllabus")
  ai_generations  AiGeneration[]

  @@index([coaching_center_id], map: "idx_syllabus_center")
  @@index([uploaded_by], map: "idx_syllabus_uploader")
  @@map("syllabuses")
}

model ContentSource {
  id                 Int       @id @default(autoincrement())
  coaching_center_id  Int
  teacher_id         Int
  source_type        String    @default("CHAT")
  raw_text           String?   @db.Text
  processed_topics   Json?
  keywords           Json?
  metadata           Json?
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  teacher         User           @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@index([coaching_center_id], map: "idx_content_sources_center")
  @@index([teacher_id], map: "idx_content_sources_teacher")
  @@map("content_sources")
}

model Topic {
  id                 Int       @id @default(autoincrement())
  coaching_center_id Int?
  name               String
  normalized_name    String
  usage_count        Int       @default(0)
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  questions       Question[]

  @@unique([coaching_center_id, normalized_name], map: "uniq_topics_center_normalized")
  @@index([coaching_center_id], map: "idx_topics_center")
  @@map("topics")
}

model AiGeneration {
  id                 Int       @id @default(autoincrement())
  coaching_center_id Int
  teacher_id         Int
  syllabus_id        Int
  num_questions      Int
  difficulty_dist    Json
  marks_per_q        Int
  negative_marking   Float?
  status             String    @default("PENDING")
  attempt_count      Int       @default(0)
  max_attempts       Int       @default(3)
  last_attempt_at    DateTime? @db.Timestamp(6)
  error_message      String?
  raw_ai_response    String?   @db.Text
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  completed_at       DateTime? @db.Timestamp(6)

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  teacher         User           @relation("AiGenerationTeacher", fields: [teacher_id], references: [id])
  syllabus        Syllabus       @relation(fields: [syllabus_id], references: [id], onDelete: Cascade)
  questions       Question[]     @relation("QuestionsInGeneration")

  @@index([coaching_center_id], map: "idx_ai_generation_center")
  @@index([status], map: "idx_ai_generation_status")
  @@index([teacher_id], map: "idx_ai_generation_teacher")
  @@map("ai_generations")
}

// ============ QUESTION & OPTIONS ============
model Question {
  id                   Int       @id @default(autoincrement())
  coaching_center_id   Int
  created_by           Int
  subject_id           Int?
  syllabus_id          Int?
  ai_generation_id     Int?
  topic_id             Int?
  question_text        String    @db.Text
  difficulty_level     String    @default("MEDIUM")
  marks                Int       @default(1)
  negative_marks       Float     @default(0)
  explanation          String?   @db.Text
  source               String?   @default("MANUAL")
  is_from_bank         Boolean   @default(false)
  usage_count          Int       @default(0)
  created_at           DateTime  @default(now()) @db.Timestamp(6)
  updated_at           DateTime  @updatedAt @db.Timestamp(6)

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  creator         User            @relation("QuestionCreatedBy", fields: [created_by], references: [id])
  subject         Subject?        @relation("QuestionSubject", fields: [subject_id], references: [id])
  syllabus        Syllabus?       @relation("QuestionsFromSyllabus", fields: [syllabus_id], references: [id])
  ai_generation   AiGeneration?   @relation("QuestionsInGeneration", fields: [ai_generation_id], references: [id])
  topic           Topic?          @relation(fields: [topic_id], references: [id])
  options         QuestionOption[]
  test_questions  TestQuestion[]
  attempts_answers TestAttemptAnswer[]
  analytics       QuestionAnalytic?

  @@index([coaching_center_id], map: "idx_question_center")
  @@index([created_by], map: "idx_question_creator")
  @@index([is_from_bank], map: "idx_question_bank")
  @@index([topic_id], map: "idx_question_topic")
  @@map("questions")
}

model QuestionOption {
  id          Int     @id @default(autoincrement())
  question_id Int
  option_text String  @db.Text
  order_index Int
  created_at  DateTime @default(now()) @db.Timestamp(6)

  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([question_id, order_index], map: "uniq_question_option_order")
  @@index([question_id], map: "idx_question_option_question")
  @@map("question_options")
}

// ============ TEST & TEST QUESTIONS ============
model Test {
  id                 Int       @id @default(autoincrement())
  coaching_center_id Int
  batch_id           Int
  subject_id         Int?
  created_by         Int
  title              String
  description        String?
  mode               String    @default("PRACTICE")
  duration_minutes   Int?
  shuffle_questions  Boolean   @default(false)
  shuffle_options    Boolean   @default(false)
  show_answers_after Boolean   @default(true)
  published_at       DateTime? @db.Timestamp(6)
  start_time         DateTime? @db.Timestamp(6)
  end_time           DateTime? @db.Timestamp(6)
  results_published  Boolean   @default(false)
  is_archived        Boolean   @default(false)
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)

  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Cascade)
  batch           Batch          @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  subject         Subject?       @relation("TestSubject", fields: [subject_id], references: [id])
  creator         User           @relation("TestCreatedBy", fields: [created_by], references: [id])
  test_questions  TestQuestion[]
  test_batches    TestBatch[]
  attempts        TestAttempt[]
  documents       Document[]     @relation("DocumentForTest")
  analytics       TestAnalytic?

  @@index([coaching_center_id], map: "idx_test_center")
  @@index([created_by], map: "idx_test_creator")
  @@index([batch_id], map: "idx_test_batch")
  @@index([published_at], map: "idx_test_published")
  @@map("tests")
}

model TestQuestion {
  id         Int @id @default(autoincrement())
  test_id    Int
  question_id Int
  order_index Int

  test     Test    @relation(fields: [test_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id], onDelete: Restrict)

  @@unique([test_id, order_index], map: "uniq_test_question_order")
  @@index([question_id], map: "idx_test_question_question")
  @@map("test_questions")
}

model TestBatch {
  id       Int @id @default(autoincrement())
  test_id  Int
  batch_id Int

  test  Test  @relation(fields: [test_id], references: [id], onDelete: Cascade)
  batch Batch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@unique([test_id, batch_id], map: "uniq_test_batch")
  @@map("test_batches")
}

// ============ TEST ATTEMPTS & ANSWERS ============
model TestAttempt {
  id                 Int       @id @default(autoincrement())
  test_id            Int
  batch_id           Int
  student_id         Int
  coaching_center_id Int
  started_at         DateTime  @default(now()) @db.Timestamp(6)
  submitted_at       DateTime? @db.Timestamp(6)
  time_taken_secs    Int?
  total_marks        Int?
  obtained_marks     Float?
  percentage         Float?
  status             String    @default("IN_PROGRESS")
  submission_count   Int       @default(0)
  max_submissions    Int       @default(1)
  created_at         DateTime  @default(now()) @db.Timestamp(6)

  test     Test    @relation(fields: [test_id], references: [id], onDelete: Restrict)
  batch    Batch   @relation(fields: [batch_id], references: [id], onDelete: Restrict)
  student  User    @relation("TestAttemptStudent", fields: [student_id], references: [id], onDelete: Restrict)
  coaching_center CoachingCenter @relation(fields: [coaching_center_id], references: [id], onDelete: Restrict)
  answers  TestAttemptAnswer[]

  @@unique([test_id, student_id], map: "uniq_test_attempt_student")
  @@index([coaching_center_id], map: "idx_test_attempt_center")
  @@index([student_id], map: "idx_test_attempt_student")
  @@index([submitted_at], map: "idx_test_attempt_submitted")
  @@map("test_attempts")
}

model TestAttemptAnswer {
  id                  Int    @id @default(autoincrement())
  attempt_id          Int
  question_id         Int
  selected_option_ids Json   @db.Json
  is_correct          Boolean?
  marks_awarded       Float?
  answered_at         DateTime @default(now()) @db.Timestamp(6)

  attempt   TestAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question  Question    @relation(fields: [question_id], references: [id], onDelete: Restrict)

  @@index([attempt_id], map: "idx_test_attempt_answer_attempt")
  @@index([question_id], map: "idx_test_attempt_answer_question")
  @@map("test_attempt_answers")
}

// ============ ANALYTICS ============
model QuestionAnalytic {
  id                  Int     @id @default(autoincrement())
  question_id         Int     @unique
  total_attempts      Int     @default(0)
  correct_count       Int     @default(0)
  incorrect_count     Int     @default(0)
  accuracy_rate       Float?
  avg_time_seconds    Int?
  difficulty_rating   Float   @default(0.5)
  last_updated_at     DateTime @updatedAt @db.Timestamp(6)

  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("question_analytics")
}

model TestAnalytic {
  id              Int     @id @default(autoincrement())
  test_id         Int     @unique
  total_attempts  Int     @default(0)
  avg_score       Float?
  median_score    Float?
  pass_count      Int     @default(0)
  last_updated_at DateTime @updatedAt @db.Timestamp(6)

  test Test @relation(fields: [test_id], references: [id], onDelete: Cascade)

  @@map("test_analytics")
}

model Fee {
  id         Int       @id @default(autoincrement())
  student_id Int?
  batch_id   Int?
  total_fee  Int?
  due_date   DateTime? @db.Date
  created_at DateTime? @default(now()) @db.Timestamp(6)

  student  User?     @relation("FeeStudent", fields: [student_id], references: [id])
  batch    Batch?    @relation(fields: [batch_id], references: [id])
  payments Payment[]

  @@map("fees")
}

model Payment {
  id          Int       @id @default(autoincrement())
  fee_id      Int?
  amount      Int?
  paid_at     DateTime? @default(now()) @db.Timestamp(6)
  recorded_by Int?

  fee      Fee?  @relation(fields: [fee_id], references: [id], onDelete: Cascade)
  recorder User? @relation("PaymentRecordedBy", fields: [recorded_by], references: [id])

  @@index([fee_id], map: "idx_payments_fee")
  @@map("payments")
}

model PaymentClaim {
  id                 Int       @id @default(autoincrement())
  student_id         Int
  batch_id           Int
  coaching_center_id Int
  amount             Int
  expected_amount    Int
  status             String    @default("PENDING")
  note               String?
  proof_url          String?
  verified_by        Int?
  verified_at        DateTime? @db.Timestamp(6)
  approved_by        Int?
  approved_at        DateTime? @db.Timestamp(6)
  rejected_reason    String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @updatedAt @db.Timestamp(6)

  student  User  @relation("ClaimCreatedBy", fields: [student_id], references: [id])
  batch    Batch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  verifier User? @relation("ClaimVerifiedBy", fields: [verified_by], references: [id])
  approver User? @relation("ClaimApprovedBy", fields: [approved_by], references: [id])

  @@index([student_id], map: "idx_payment_claims_student")
  @@index([coaching_center_id, status], map: "idx_payment_claims_coaching_status")
  @@index([batch_id], map: "idx_payment_claims_batch")
  @@index([student_id, status, created_at], map: "idx_payment_claims_student_status_created")
  @@index([student_id, created_at], map: "idx_payment_claims_student_created")
  @@map("payment_claims")
}

model Notice {
  id                 Int       @id @default(autoincrement())
  title              String?
  content            String?
  coaching_center_id Int?
  created_by         Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)

  coaching_center CoachingCenter? @relation(fields: [coaching_center_id], references: [id])
  creator         User?           @relation("NoticeCreatedBy", fields: [created_by], references: [id])
  targets         NoticeTarget[]

  @@map("notices")
}

model NoticeTarget {
  id        Int  @id @default(autoincrement())
  notice_id Int?
  batch_id  Int?

  notice Notice? @relation(fields: [notice_id], references: [id], onDelete: Cascade)
  batch  Batch?  @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@map("notice_targets")
}

model Document {
  id                Int       @id @default(autoincrement())
  title             String?
  storage_provider   String?   @default("r2")
  storage_object_key String?
  file_url          String?
  batch_id          Int?
  subject_id        Int?
  lecture_id        Int?
  test_id           Int?
  uploaded_by       Int?
  uploaded_at       DateTime? @default(now()) @db.Timestamp(6)

  batch    Batch?   @relation(fields: [batch_id], references: [id])
  subject  Subject? @relation(fields: [subject_id], references: [id])
  lecture  Lecture? @relation(fields: [lecture_id], references: [id])
  test     Test?    @relation("DocumentForTest", fields: [test_id], references: [id])
  uploader User?    @relation("DocumentUploadedBy", fields: [uploaded_by], references: [id])

  @@map("documents")
}
